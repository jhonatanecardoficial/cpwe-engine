{
  "name": "cpwe-engine",
  "version": "1.0.0",
  "description": "Content Production Workflow Engine (CPWE)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start.watch": "nodemon src/worker.ts",
    "start": "mkdir -p logs && node dist/worker.js > logs/worker.log 2>&1; sleep infinity",
    "trigger": "ts-node src/client-trigger.ts"
  },
  "dependencies": {
    "@temporalio/activity": "^1.11.2",
    "@temporalio/client": "^1.11.2",
    "@temporalio/worker": "^1.11.2",
    "@temporalio/workflow": "^1.11.2",
    "dotenv": "^16.4.5",
    "openai": "^4.76.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
